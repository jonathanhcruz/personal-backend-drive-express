# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/privatedrive

# JWT
JWT_SECRET=your-access-secret-here
REFRESH_TOKEN_SECRET=your-refresh-secret-here-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# Storage
STORAGE_PATH=/mnt/jon-disk
MAX_FILE_SIZE_MB=100
ALLOWED_MIME_TYPES=

# CORS
FRONTEND_URL=http://localhost:5173
